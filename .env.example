# Copie este arquivo para .env e preencha com suas chaves reais
# cp .env.example .env

# Chave secreta do Flask (gere uma aleatória para produção)
SECRET_KEY=sua-chave-secreta-aqui

# Chave da API do Glovo
GLOVO_API_KEY=sua-chave-glovo-aqui

# Chave da API do Unsplash (para o script de download de imagens)
UNSPLASH_ACCESS_KEY=sua-chave-unsplash-aqui
